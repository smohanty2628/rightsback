# ─── Server ───────────────────────────────────────────
PORT=3000

# ─── Email (Gmail) ────────────────────────────────────
# Step 1: Go to your Google Account → Security → 2-Step Verification → App Passwords
# Step 2: Create an App Password for "Mail"
# Step 3: Paste the 16-character password below (no spaces)

GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Email that receives notifications when someone submits
NOTIFY_EMAIL=your-email@gmail.com

# ─── App ──────────────────────────────────────────────
APP_NAME=Rights Back
APP_URL=http://localhost:3000

ADMIN_USER=your_admin_username
ADMIN_PASS=your_secure_password
ANTHROPIC_API_KEY=sk-ant-api03-your-key-here

# Optional: GROQ API key if needed
# GROQ_API_KEY=gsk_your-key-here